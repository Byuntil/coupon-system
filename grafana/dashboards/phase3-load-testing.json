      "id": 1,
      "title": "Admission TPS (P3-1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "refId": "A",
          "query": "SELECT non_negative_derivative(count(\"value\"), 1s) FROM \"p3_accepted\" WHERE $timeFilter GROUP BY time(1s) fill(0)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        },
        "overrides": []
      }
    },
